# Port the HTTP server listens on (avoids 4200 and 5021)
PORT=3001

# GitHub webhook secret — must match the value set in GitHub webhook settings
WEBHOOK_SECRET=your-webhook-secret-here

# Absolute path to the repo root where `claude` will be invoked
REPO_PATH=C:/Dev/AI/TournamentOrganizer

# The project board status name that triggers /implement-next (case-insensitive)
STATUS_TRIGGER=Ready
